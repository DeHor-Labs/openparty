{
  "manifest_version": 3,
  "name": "OpenParty",
  "version": "0.1.0",
  "description": "Assista a videos em sincronia com amigos.",
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.netflix.com/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/watch*",
        "*://*.netflix.com/watch*"
      ],
      "js": ["src/content/content-main.ts"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "OpenParty"
  },
  "options_page": "src/options/options.html",
  "web_accessible_resources": [
    {
      "resources": ["src/content/overlay/*"],
      "matches": [
        "*://*.youtube.com/*",
        "*://*.netflix.com/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
